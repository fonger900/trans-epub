# Azure Translator (optional)
AZURE_TRANSLATOR_KEY=your_azure_key
AZURE_TRANSLATOR_REGION=southeastasia

# Google Gemini (optional)
GEMINI_API_KEY=your_gemini_key

# DeepSeek (optional) — https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_key

# Alibaba Cloud Model Studio (optional)
# Get your API key from: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=your_key
# If using a workspace-scoped key (sk-ws-...), set the workspace endpoint:
# DASHSCOPE_API_BASE=https://{WorkspaceId}.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
# Otherwise the default international endpoint is used automatically.
# DASHSCOPE_MODEL=qwen3-flash   # optional, override model name
