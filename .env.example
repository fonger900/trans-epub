# trans-epub secrets
#
# Copy this file to .env and fill in your API keys
# Use `cp .env.example .env` then edit .env with your keys

# Only put SECRET values here (API keys)
# Configuration goes in config.toml file

# ── Translation Engine API Keys ────────────────────────────────────────────────
# Only set the key for the engine(s) you plan to use

# Azure Translator (free tier: 2M chars/month)
# AZURE_TRANSLATOR_KEY=

# Google Gemini
# GEMINI_API_KEY=

# DeepSeek
# DEEPSEEK_API_KEY=

# Alibaba Cloud Model Studio (DashScope)
DASHSCOPE_API_KEY=your_alibaba_api_key_here

# Google Cloud Translation
# GOOGLE_TRANSLATE_API_KEY=

# DeepL (free tier: 500K chars/month)
# DEEPL_API_KEY=

# ── Optional Settings (Secrets Only) ───────────────────────────────────────────

# Alibaba workspace-specific endpoint (contains workspace ID)
# DASHSCOPE_API_BASE=https://ws-yourworkspace.region.maas.aliyuncs.com/compatible-mode/v1

# Azure region (if not global)
# AZURE_TRANSLATOR_REGION=your-region

# Gemini model override
# GEMINI_MODEL=gemini-2.5-flash

# DeepL Pro endpoint (set this if you have a paid plan)
# DEEPL_API_BASE=https://api.deepl.com/v2/translate
